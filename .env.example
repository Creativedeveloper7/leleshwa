# Sanity CMS (public — safe for frontend)
VITE_SANITY_PROJECT_ID=th48chxn
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2025-01-01

# Write token — used only by `npm run seed:sanity` (never commit this)
# Create at: https://www.sanity.io/manage/project/th48chxn/api
SANITY_API_WRITE_TOKEN=

# Newsletter API (optional override)
# VITE_NEWSLETTER_API_URL=/api/newsletter/subscribe

# Supabase public browser configuration
# Safe to expose through Vite. Find these under Project Settings > API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase Edge Function runtime values
# Supabase injects these automatically in hosted functions. Supply them in a
# local-only env file when running functions locally. Never expose service role
# through a VITE_ variable.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend transactional email
# Verify the official Leleshwa domain in Resend before using the reservations address.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Leleshwa Reservations <reservations@example.com>
RESEND_REPLY_TO=reservations@example.com
RESERVATIONS_EMAIL=reservations@example.com
ADMIN_DASHBOARD_URL=https://example.com/admin/

# Exact production site origin, for example https://leleshwa.example
# Use * only during local development.
ALLOWED_ORIGIN=http://localhost:5173

